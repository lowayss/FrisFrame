{
  "name": "frisframe-desktop",
  "version": "0.2.8",
  "private": true,
  "description": "FrisFrame desktop previs studio",
  "main": "electron/main.cjs",
  "author": "FrisFrame",
  "license": "UNLICENSED",
  "scripts": {
    "icon:build": "node electron/scripts/build-icon.cjs",
    "vendor:sync": "node electron/scripts/sync-vendor.cjs",
    "server:bundle": "node electron/scripts/build-python-runtime.cjs",
    "desktop:prepare": "npm run icon:build && npm run vendor:sync && npm run server:bundle",
    "desktop:dev": "npm run vendor:sync && electron .",
    "desktop:dir": "npm run desktop:prepare && electron-builder --mac dir --arm64",
    "desktop:build": "npm run desktop:prepare && electron-builder --mac dmg zip --arm64",
    "desktop:migrate-data": "node electron/scripts/migrate-local-data.cjs",
    "desktop:verify": "node electron/scripts/verify-package.cjs",
    "check": "python3 quality_check.py && node tests/electron-contract.test.cjs"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "ffmpeg-static": "5.3.0",
    "lucide": "0.468.0",
    "three": "0.160.0"
  },
  "build": {
    "appId": "studio.frisframe.desktop",
    "productName": "FrisFrame",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/main.cjs",
      "electron/clipboard.cjs",
      "electron/preload.cjs",
      "electron/startup.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-runtime/frisframe-server",
        "to": "runtime/server"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "runtime/ffmpeg"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "licenses/THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.LICENSE",
        "to": "licenses/FFmpeg-LICENSE.txt"
      },
      {
        "from": "node_modules/three/LICENSE",
        "to": "licenses/Three.js-LICENSE.txt"
      },
      {
        "from": "node_modules/lucide/LICENSE",
        "to": "licenses/Lucide-LICENSE.txt"
      }
    ],
    "afterPack": "electron/after-pack.cjs",
    "artifactName": "FrisFrame-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "FrisFrame ${version}",
      "window": {
        "width": 560,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 185
        },
        {
          "x": 410,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
